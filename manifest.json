{
  "manifest_version": 3,
  "name": "NeuroNav",
  "version": "1.0",
  "description": "Control your browser with hand gestures.",
  "icons": {
    "24": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "24": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "NeuroNav"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "system.display",
    "sessions",
    "bookmarks"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "type": "module"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ai_bridge.js",
        "vision_bundle.js",
        "vision_wasm_internal.wasm",
        "vision_wasm_internal.js",
        "vision_wasm_nosimd_internal.js",
        "vision_wasm_nosimd_internal.wasm",
        "hand_landmarker.task"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}